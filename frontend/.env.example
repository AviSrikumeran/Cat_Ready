# Backend API base URL (no trailing slash). Used when submitting inspections.
# Default below works when testing on the same machine.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# To test on phone/tablet: use your laptop's IP so the device can reach the API.
# Example (replace with your IP): NEXT_PUBLIC_API_URL=http://192.168.1.105:8000/api
